# Optional Lemon Squeezy billing scaffold
# Required for server-side checkout creation
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
# Required for /api/lemonsqueezy-webhook signature verification
LEMONSQUEEZY_WEBHOOK_SECRET=

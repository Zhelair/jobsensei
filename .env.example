LEMONSQUEEZY_ALLOWED_PRODUCT_IDS=
LEMONSQUEEZY_ALLOWED_PRODUCT_NAMES=
LEMONSQUEEZY_ALLOWED_VARIANT_IDS=
LEMONSQUEEZY_ALLOWED_VARIANT_NAMES=
# Set to true while testing checkout creation in Lemon Squeezy test mode
LEMONSQUEEZY_CHECKOUT_TEST_MODE=
# Set to true only when you want the web app to expose Lemon Squeezy checkout
VITE_LEMONSQUEEZY_ENABLED=

# Optional while migrating from older setup names
SUPABASE_SECRET_KEY=
